        </button>
        <button class="nav-btn" onclick="navigate('booster')">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"></path></svg>
            <span>Turbo Booster</span>
        </button>
        <button class="nav-btn" onclick="navigate('settings')">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg>
            <span>Pengaturan</span>
        </button>
    </aside>

    <!-- Main Content -->
    <main>
        <header>
            <div class="page-title">
                <h2 id="header-title">Dashboard</h2>
                <p id="header-desc">Ringkasan kinerja sistem Windows</p>
            </div>
            <div class="header-right">
                <div class="clock" id="clock">00:00:00</div>
                <div style="width: 35px; height: 35px; background: #334155; border-radius: 50%; display:flex; align-items:center; justify-content:center;">A</div>
            </div>
        </header>

        <div class="content-area">

            <!-- 1. DASHBOARD PAGE -->
            <div id="page-dashboard" class="page active">
                <div class="grid-3">
                    <div class="card" style="grid-column: span 1;">
                        <h3 style="color:var(--text-muted); font-size:14px; margin-bottom:15px;">Kesehatan PC</h3>
                        <div class="health-gauge" id="health-gauge">
                            <div class="health-score">
                                <h1 id="health-val">78</h1>
                                <span>Baik</span>
                            </div>
                        </div>
                        <p style="text-align:center; color:var(--text-muted); font-size:13px;">Perlu pembersihan untuk performa maksimal.</p>
                    </div>
                    
                    <div class="card" style="grid-column: span 2;">
                        <h3 style="color:var(--text-muted); font-size:14px; margin-bottom:20px;">Penggunaan Sumber Daya</h3>
                        
                        <div class="stat-row">
                            <span>CPU (Intel Core i7)</span>
                            <span id="cpu-text">34%</span>
                        </div>
                        <div class="stat-bar-bg"><div class="stat-bar-fill" id="cpu-bar" style="width:34%; background: #3b82f6;"></div></div>
