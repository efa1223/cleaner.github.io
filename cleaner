    <script>
        // --- Navigation Logic ---
        function navigate(pageId) {
            // Update Title
            const titles = {
                'dashboard': ['Dashboard', 'Ringkasan kinerja sistem Windows'],
                'cleaner': ['System Cleaner', 'Hapus file sampah dan registry error'],
                'startup': ['Startup Manager', 'Kelola aplikasi saat booting'],
                'booster': ['Turbo Booster', 'Optimasi performa instan'],
                'settings': ['Pengaturan', 'Konfigurasi preferensi aplikasi']
            };
            document.getElementById('header-title').innerText = titles[pageId][0];
            document.getElementById('header-desc').innerText = titles[pageId][1];

            // Switch Pages
            document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
            document.getElementById('page-' + pageId).classList.add('active');

            // Update Sidebar
            document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
            // This is a simple match logic based on onclick attribute string
            const activeBtn = Array.from(document.querySelectorAll('.nav-btn')).find(btn => btn.getAttribute('onclick').includes(pageId));
            if(activeBtn) activeBtn.classList.add('active');
        }

        // --- Clock Logic ---
        setInterval(() => {
            const now = new Date();
            document.getElementById('clock').innerText = now.toLocaleTimeString('id-ID');
        }, 1000);

        // --- Dashboard Simulation (Live Stats) ---
        setInterval(() => {
            // Random CPU fluctuation
            const cpu = Math.floor(Math.random() * (45 - 20) + 20);
            document.getElementById('cpu-text').innerText = cpu + "%";
            document.getElementById('cpu-bar').style.width = cpu + "%";

            // Slight RAM fluctuation
            const ramBase = 32;
            const ramFlux = Math.floor(Math.random() * 5);
            document.getElementById('ram-bar').style.width = (ramBase + ramFlux) + "%";
            document.getElementById('ram-text').innerText = (5.0 + (ramFlux/10)).toFixed(1) + " GB / 16 GB";
        }, 2000);

        // --- Cleaner Logic ---
        let totalJunkSize = 0;

        function startScan() {
            const btn = document.getElementById('btn-scan');
            const status = document.getElementById('scan-status');
            const progress = document.getElementById('scan-progress');
            const fill = document.getElementById('scan-fill');
            const results = document.getElementById('scan-results');

            btn.disabled = true;
            btn.style.display = 'none';
            status.style.display = 'block';
            progress.style.display = 'block';
            results.innerHTML = '';

            let width = 0;
            const interval = setInterval(() => {
                width += Math.random() * 5;
                if (width > 100) width = 100;
                fill.style.width = width + '%';

                if (width >= 100) {
                    clearInterval(interval);
                    finishScan();
                }
            }, 100);
        }

        function finishScan() {
            const status = document.getElementById('scan-status');
            const btnClean = document.getElementById('btn-clean');
            const results = document.getElementById('scan-results');
            
            status.style.display = 'none';
            btnClean.style.display = 'inline-flex';
            
            // Mock Data
            const items = [
                { name: "Windows Error Reports", size: 145 },
                { name: "Temporary Files", size: 890 },
                { name: "Font Cache", size: 45 },
                { name: "Browser Cache (Chrome)", size: 320 },
                { name: "Invalid Registry Keys", size: 120 },
            ];

            totalJunkSize = 0;
            items.forEach(item => {
                totalJunkSize += item.size;
                const div = document.createElement('div');
                div.className = 'scan-item';
                div.innerHTML = `
                    <div style="display:flex; align-items:center; gap:10px;">
                        <span style="color:var(--danger);">✕</span> ${item.name}
                    </div>
                    <span style="color:var(--text-muted);">${item.size} MB</span>
                `;
                results.appendChild(div);
            });

            showToast(`Pemindaian Selesai! ${totalJunkSize} MB sampah ditemukan.`);
        }

        function startClean() {
            const btnClean = document.getElementById('btn-clean');
            const results = document.getElementById('scan-results');
            
            btnClean.disabled = true;
            btnClean.innerHTML = 'Membersihkan...';

            let items = document.querySelectorAll('.scan-item');
            let delay = 0;

            items.forEach((item, index) => {
                setTimeout(() => {
                    item.style.transform = 'translateX(50px)';
                    item.style.opacity = '0';
                    item.style.transition = 'all 0.3s';
                }, delay);
                delay += 200;
            });

            setTimeout(() => {
                results.innerHTML = '<div style="text-align:center; padding:20px; color:var(--primary);">✓ Sistem bersih!</div>';
                btnClean.innerHTML = 'Selesai';
                btnClean.className = 'btn btn-ghost';
                btnClean.disabled = false;
                btnClean.onclick = () => { /* Reset state could go here */ };
                
                // Update Dashboard Health visually
                const gauge = document.getElementById('health-gauge');
                gauge.style.background = `conic-gradient(var(--primary) ${84 * 3.6}deg, var(--bg-panel) 0deg)`;
                document.getElementById('health-val').innerText = "92";
                showToast("Berhasil menghapus " + totalJunkSize + " MB file sampah.");
            }, delay + 500);
        }

        // --- Startup Manager Logic ---
        const startupApps = [
            { name: "Spotify Web Helper", status: true, delay: "2.1s" },
            { name: "Steam Client Bootstrapper", status: true, delay: "4.5s" },
            { name: "Microsoft Teams", status: true, delay: "3.2s" },
            { name: "Adobe Updater", status: false, delay: "1.5s" },
            { name: "Google Drive", status: true, delay: "2.8s" },
        ];

        function renderStartup() {
            const list = document.getElementById('startup-list');
            list.innerHTML = '';
            let totalTime = 12; // Base OS time

            startupApps.forEach((app, index) => {
                if(app.status) totalTime += parseFloat(app.delay);

                const div = document.createElement('div');
                div.className = 'app-row';
                div.innerHTML = `
                    <div class="app-info">
                        <div class="app-icon">${app.name.charAt(0)}</div>
                        <div>
                            <div style="font-weight:500; font-size:14px;">${app.name}</div>
                            <div style="font-size:12px; color:var(--text-muted);">Delay: ${app.delay}</div>
                        </div>
                    </div>
                    <label class="switch">
                        <input type="checkbox" ${app.status ? 'checked' : ''} onchange="toggleStartup(${index})">
                        <span class="slider"></span>
                    </label>
                `;
                list.appendChild(div);
            });

            document.getElementById('boot-time').innerText = totalTime.toFixed(1);
        }

        function toggleStartup(index) {
            startupApps[index].status = !startupApps[index].status;
            renderStartup();
            
            if(!startupApps[index].status) {
                showToast(`${startupApps[index].name} dinonaktifkan dari startup.`);
            } else {
                showToast(`${startupApps[index].name} diaktifkan.`);
            }
        }

        function resetStartup() {
            startupApps.forEach(app => app.status = true);
            renderStartup();
            showToast("Startup direset ke default.");
        }

        // --- Turbo Booster Logic ---
        function activateBoost() {
            const btn = document.getElementById('btn-boost');
            const status = document.getElementById('boost-status');
            
            btn.disabled = true;
            btn.innerHTML = "MENGHENTIKAN PROSES...";
            status.style.display = 'block';

            setTimeout(() => {
                btn.innerHTML = "BOOST SELESAI";
                btn.className = "btn btn-ghost"; // Change style
                btn.style.borderColor = "var(--primary)";
                btn.style.color = "var(--primary)";
                
                status.innerHTML = "✓ RAM Dibebaskan: 1.2 GB | Jaringan Dioptimalkan";
                
                // Simulate RAM drop on dashboard (even if not visible yet)
                document.getElementById('ram-text').innerText = "3.8 GB / 16 GB";
                document.getElementById('ram-bar').style.width = "23%";

                showToast("Turbo Booster Diaktifkan! Performa maksimal.");
            }, 2500);
        }

        // --- Utility: Toast Notification ---
        function showToast(message) {
            const container = document.getElementById('toast-container');
            const toast = document.createElement('div');
            toast.className = 'toast';
            toast.innerHTML = `
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                <span>${message}</span>
            `;
            container.appendChild(toast);

            setTimeout(() => {
                toast.style.opacity = '0';
                toast.style.transform = 'translateY(20px)';
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }

        // Init
        renderStartup();
    </script>
</body>
</html>
