                            <div style="font-weight:600;">System Junk</div>
                            <div style="font-size:12px; color:var(--text-muted); margin-top:5px;">Temp, Log, Cache</div>
                        </label>
                        <label class="clean-option-card selected">
                            <input type="checkbox" checked value="privacy">
                            <div class="clean-option-icon">🔒</div>
                            <div style="font-weight:600;">Privacy Trace</div>
                            <div style="font-size:12px; color:var(--text-muted); margin-top:5px;">History, Cookies</div>
                        </label>
                    </div>

                    <div style="text-align:center; margin-bottom:20px;">
