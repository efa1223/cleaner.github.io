                        <div class="stat-row">
                            <span>Penyimpanan (SSD C:)</span>
                            <span>120 GB / 512 GB</span>
                        </div>
                        <div class="stat-bar-bg"><div class="stat-bar-fill" style="width:23%; background: #f59e0b;"></div></div>
                    </div>
                </div>

                <div class="card" style="margin-top:25px;">
                    <div style="display:flex; justify-content:space-between; align-items:center;">
                        <div>
                            <h3>Aksi Cepat</h3>
                            <p style="color:var(--text-muted); font-size:13px;">Lakukan optimasi satu klik sekarang.</p>
                        </div>
                        <button class="btn btn-primary" onclick="navigate('cleaner')">
