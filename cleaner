<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WinBoost X10 Pro - Ultimate Optimizer</title>
    <!-- Menggunakan Font Google: Inter untuk tampilan profesional -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-dark: #0f172a;
            --bg-panel: #1e293b;
            --primary: #10b981; /* Emerald Green */
            --primary-hover: #059669;
            --accent: #3b82f6; /* Blue */
            --text-main: #f1f5f9;
            --text-muted: #94a3b8;
            --danger: #ef4444;
            --border: #334155;
            --glass: rgba(30, 41, 59, 0.7);
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Inter', sans-serif;
            scrollbar-width: thin;
            scrollbar-color: var(--border) var(--bg-dark);
        }

        body {
            background-color: var(--bg-dark);
            color: var(--text-main);
            height: 100vh;
            display: flex;
            overflow: hidden;
        }

        /* --- Sidebar --- */
        aside {
            width: 260px;
            background-color: var(--bg-panel);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            padding: 20px;
            z-index: 20;
            transition: width 0.3s;
        }

        .brand {
            font-size: 22px;
            font-weight: 800;
            color: var(--text-main);
            margin-bottom: 40px;
            display: flex;
            align-items: center;
            gap: 12px;
            letter-spacing: -0.5px;
        }
        
        .brand span { color: var(--primary); }

        .menu-label {
            font-size: 11px;
            text-transform: uppercase;
            color: var(--text-muted);
            font-weight: 600;
            margin-bottom: 10px;
            margin-top: 20px;
            padding-left: 10px;
        }

        .nav-btn {
            background: transparent;
            border: none;
            width: 100%;
            padding: 12px 15px;
            text-align: left;
            color: var(--text-muted);
            cursor: pointer;
            border-radius: 10px;
            transition: all 0.2s;
            font-size: 14px;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 5px;
        }

        .nav-btn:hover {
            background-color: rgba(255, 255, 255, 0.05);
            color: var(--text-main);
        }

        .nav-btn.active {
            background: linear-gradient(90deg, rgba(16, 185, 129, 0.15), transparent);
            color: var(--primary);
            border-left: 3px solid var(--primary);
        }

        .nav-btn svg { width: 18px; height: 18px; }

        .pro-badge {
            background: linear-gradient(135deg, #f59e0b, #d97706);
            color: white;
            font-size: 10px;
            padding: 2px 6px;
            border-radius: 4px;
            margin-left: auto;
            font-weight: 700;
        }

        /* --- Main Content --- */
        main {
            flex: 1;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            background: radial-gradient(circle at top right, #1e293b 0%, #0f172a 40%);
        }

        header {
            height: 70px;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 30px;
            background-color: rgba(15, 23, 42, 0.8);
            backdrop-filter: blur(10px);
        }

        .page-title h2 { font-size: 20px; font-weight: 600; }
        .page-title p { font-size: 12px; color: var(--text-muted); }

        .header-right { display: flex; align-items: center; gap: 20px; }
        .clock { font-family: monospace; font-size: 14px; color: var(--primary); background: rgba(16, 185, 129, 0.1); padding: 5px 10px; border-radius: 5px; }

        /* --- Content Pages --- */
        .content-area {
            flex: 1;
            padding: 30px;
            overflow-y: auto;
            position: relative;
        }

        .page { display: none; animation: fadeIn 0.4s ease; }
        .page.active { display: block; }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* --- Components --- */
        .card {
            background-color: var(--bg-panel);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 25px;
            position: relative;
            overflow: hidden;
        }

        .btn {
            padding: 12px 24px;
            border-radius: 8px;
            border: none;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-size: 14px;
        }

        .btn-primary { background: var(--primary); color: #fff; box-shadow: 0 4px 12px rgba(16, 185, 129, 0.3); }
        .btn-primary:hover { background: var(--primary-hover); transform: translateY(-1px); }
        .btn-danger { background: var(--danger); color: white; }
        .btn-ghost { background: transparent; border: 1px solid var(--border); color: var(--text-muted); }
        .btn-ghost:hover { border-color: var(--text-main); color: var(--text-main); }

        .grid-2 { display: grid; grid-template-columns: 2fr 1fr; gap: 25px; }
        .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 25px; }

        /* --- Dashboard Specific --- */
        .health-gauge {
            width: 180px;
            height: 180px;
            border-radius: 50%;
            background: conic-gradient(var(--primary) 0deg, var(--bg-panel) 0deg);
            margin: 0 auto 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            transition: background 1s ease;
        }
        
        .health-gauge::before {
            content: "";
            position: absolute;
            width: 150px;
            height: 150px;
            background-color: var(--bg-panel);
            border-radius: 50%;
        }

        .health-score {
            position: absolute;
            z-index: 2;
            text-align: center;
        }
        .health-score h1 { font-size: 42px; color: var(--text-main); line-height: 1; }
        .health-score span { font-size: 12px; color: var(--text-muted); }

        .stat-row { display: flex; justify-content: space-between; margin-bottom: 12px; font-size: 14px; }
        .stat-bar-bg { width: 100%; height: 6px; background: #334155; border-radius: 3px; overflow: hidden; }
        .stat-bar-fill { height: 100%; background: var(--accent); width: 0%; transition: width 0.5s ease; }

        /* --- Cleaner Specific --- */
        .clean-options { display: grid; grid-template-columns: repeat(3, 1fr); gap: 15px; margin-bottom: 25px; }
        .clean-option-card {
            background: rgba(255,255,255,0.03);
            border: 1px solid var(--border);
            padding: 15px;
            border-radius: 12px;
            cursor: pointer;
            transition: all 0.2s;
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
        }
        .clean-option-card:hover, .clean-option-card.selected { border-color: var(--primary); background: rgba(16, 185, 129, 0.05); }
        .clean-option-card input { display: none; }
        .clean-option-icon { font-size: 24px; margin-bottom: 10px; }
        
        .scan-result-list { max-height: 300px; overflow-y: auto; margin-top: 20px; }
        .scan-item {
            display: flex;
            justify-content: space-between;
            padding: 12px;
            border-bottom: 1px solid rgba(255,255,255,0.05);
            font-size: 14px;
        }

        /* --- Startup Manager --- */
        .app-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 15px 0;
            border-bottom: 1px solid rgba(255,255,255,0.05);
        }
        .app-info { display: flex; align-items: center; gap: 15px; }
        .app-icon { width: 32px; height: 32px; background: #334155; border-radius: 6px; display: flex; align-items: center; justify-content: center; font-size: 14px; }
        
        /* Toggle Switch */
        .switch { position: relative; display: inline-block; width: 40px; height: 22px; }
        .switch input { opacity: 0; width: 0; height: 0; }
        .slider {
            position: absolute; cursor: pointer; top: 0; left: 0; right: 0; bottom: 0;
            background-color: #334155; transition: .4s; border-radius: 34px;
        }
        .slider:before {
            position: absolute; content: ""; height: 16px; width: 16px; left: 3px; bottom: 3px;
            background-color: white; transition: .4s; border-radius: 50%;
        }
        input:checked + .slider { background-color: var(--primary); }
        input:checked + .slider:before { transform: translateX(18px); }

        /* --- Toast Notification --- */
        #toast-container { position: fixed; bottom: 30px; right: 30px; z-index: 100; display: flex; flex-direction: column; gap: 10px; }
        .toast {
            background: var(--bg-panel); border-left: 4px solid var(--primary); padding: 15px 20px;
            border-radius: 4px; box-shadow: 0 10px 30px rgba(0,0,0,0.5); display: flex; align-items: center; gap: 10px;
            min-width: 280px; animation: slideIn 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        }
        @keyframes slideIn { from { transform: translateX(100%); opacity: 0; } to { transform: translateX(0); opacity: 1; } }

        /* --- Responsiveness --- */
        @media (max-width: 900px) {
            .grid-2, .grid-3, .clean-options { grid-template-columns: 1fr; }
            aside { width: 70px; padding: 15px 10px; }
            .brand span, .nav-btn span, .menu-label, .pro-badge { display: none; }
            .nav-btn { justify-content: center; padding: 15px 0; }
        }
    </style>
</head>
<body>

    <!-- Sidebar -->
    <aside>
        <div class="brand">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:var(--primary)"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
            <span>WinBoost X10</span>
        </div>

        <div class="menu-label">Menu Utama</div>
        <button class="nav-btn active" onclick="navigate('dashboard')">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
